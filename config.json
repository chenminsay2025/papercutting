{
  "serial": {
    "port": "SIM（模拟）",
    "baudrate": 115200,
    "timeout_ms": 2000
  },
  "timings_ms": {
    "retract": 500,
    "extend": 500,
    "cut_wait": 100,
    "relay_pulse": 200,
    "before_send_keys": 200,
    "after_focus_ms": 500,
    "after_hotkey_ms": 1000
  },
  "cutting_master": {
    "window_title_contains": "Cutting Master",
    "send_hotkey": "ctrl+p"
  },
  "app": {
    "simulation_mode": true,
    "simulate_cut": false,
    "auto_loop": true,
    "loop_interval_ms": 100
  },
  "workflow_steps": [
    {
      "id": "step-retract",
      "type": "retract",
      "enabled": true,
      "label": "伸缩杆缩回",
      "duration_ms": 3000
    },
    {
      "id": "step-pulse-a",
      "type": "pulse_a",
      "enabled": true,
      "label": "继续 (继电器A)",
      "duration_ms": 200
    },
    {
      "id": "step-focus",
      "type": "focus_window",
      "enabled": true,
      "label": "获取窗口",
      "window_keyword": "Cutting Master",
      "focus_timeout_ms": 800
    },
    {
      "id": "step-hotkey",
      "type": "send_hotkey",
      "enabled": true,
      "label": "发送快捷键",
      "hotkey": "ctrl+p",
      "delay_before_ms": 100,
      "delay_after_ms": 200
    },
    {
      "id": "step-cut-wait",
      "type": "cut_wait",
      "enabled": true,
      "label": "等待切割",
      "duration_ms": 6000
    },
    {
      "id": "step-extend",
      "type": "extend",
      "enabled": true,
      "label": "伸缩杆伸出",
      "duration_ms": 3000
    },
    {
      "id": "step-pulse-b",
      "type": "pulse_b",
      "enabled": true,
      "label": "原点 (继电器B)",
      "duration_ms": 200
    }
  ]
}
